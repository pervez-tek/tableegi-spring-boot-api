#Admin Credentials Token Expiration redirect to Login screen
server.servlet.session.timeout=${SPRING_AUTO_EXPIRE_SESSION_ID_CRON_EXPR}
spring.auto.expire.cron.expr=${SPRING_AUTO_EXPIRE_JOB_CRON_EXPR}
spring.auto.expire.session.id.token.valid.mins=${SPRING_AUTO_EXPIRE_JOB_SESSION_TOKEN_VALID_MINS}


#Notifications Emai,SMS,Whatsapp
tableegi.publish.email.notification=${PUBLISH_EMAIL_NOTIFICATION}
tableegi.publish.sms.notification=${PUBLISH_SMS_NOTIFICATION}
tableegi.publish.whatsapp.notification=${PUBLISH_WHATSAPP_NOTIFICATION}


# SMTP Email Configurations
spring.mail.host=${SMTP_MAIL_HOST}
spring.mail.port=${SMTP_MAIL_PORT}
spring.mail.username=${SMTP_MAIL_USERNAME}
spring.mail.password=${SMTP_MAIL_PASSWORD}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=3000
spring.mail.properties.mail.smtp.writetimeout=5000
spring.smtp.from.email=${SMTP_EMAIL_FROM}

#Twillio Configuration
twilio.account.id=${TWILIO_ACCOUNT_SID}
twilio.auth.id=${TWILIO_AUTH_ID}
twilio.whatsapp.from.number=${TWILIO_WHATSAPP_FROM_NUMBER}
twilio.sms.from.number=${TWILIO_SMS_FROM_NUMBER}
twilio.whatsapp.link=${TWILIO_WHATSAPP_LINK}


