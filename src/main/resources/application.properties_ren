spring.application.name=tableegi-spring-boot-api
front.end.react.api.url=${FRONT_END_ORIGIN}
#DB Configuration
spring.datasource.url=${SPRING_JDBC_DATASOURCE_URL}
spring.datasource.username=${SPRING_JDBC_USERNAME}
spring.datasource.password=${SPRING_JDBC_PASSWORD}
spring.datasource.driver-class-name=${SPRING_DATASOURCE_DRIVER_CLASS_NAME}
spring.jpa.properties.hibernate.jdbc.time_zone=Asia/Kolkata
#Oauth for GOOGLE authorization framework
spring.security.oauth2.client.registration.google.client-id=${SPRING_BOOT_GOOGLE_CLIENT_REG_CLIENT_ID}
spring.security.oauth2.client.registration.google.client-secret=${SPRING_BOOT_GOOGLE_CLIENT_REG_CLIENT_SECRET}
spring.security.oauth2.client.registration.google.scope=${SPRING_BOOT_GOOGLE_CLIENT_REG_CLIENT_SCOPE}
spring.security.oauth2.client.provider.google.user-info-uri=${SPRING_BOOT_GOOGLE_CLIENT_REG_CLIENT_USER_INFO_URI}
spring.security.oauth2.client.registration.google.redirect-uri=${SPRING_BOOT_GOOGLE_CLIENT_REG_CLIENT_REDIRECT_URI}
spring.security.oauth2.client.provider.google.authorization-uri=${SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_GOOGLE_AUTHORIZATION_URI}
spring.security.oauth2.client.provider.google.token-uri=${SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_GOOGLE_TOKEN_URI}
spring.security.oauth2.client.provider.google.user-name-attribute={SPRING_SECURITY_OAUTH2_CLIENT_PROVIDER_GOOGLE_USER_NAME_ATTRIBUTE}
#User Profile Pics Downloaded URL Path
spring.boot.google.profiles=${SPRING_BOOT_GOOGLE_PROFILES_PICTURES}


#SSL Configuration
server.port=${PORT:8080}
